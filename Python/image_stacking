import os
import numpy as np
from astropy.io import fits
import astroalign as aa
import matplotlib.pyplot as plt
import scipy.ndimage as ndimage

# 1. Map en bestanden inladen
map_fits = '/Users/ilkatonnaer/Documents/AA Uni/jaar 1 (2nd edition)/Eerstejaarsproject/reduced_data/Ha 2'

alle_fits = sorted([
    os.path.join(map_fits, f)
    for f in os.listdir(map_fits)
    if f.lower().endswith('.fits')
])

print("Aantal frames gevonden:", len(alle_fits))

# 2. Referentieframe instellen en opschonen (hot pixels verwijderen)
# Als frame 0 niet werkt, verander de 0 hieronder dan in een ander getal (bijv. 5)
reference = np.array(fits.getdata(alle_fits[14]), dtype=np.float64)
ref_clean = ndimage.median_filter(reference, size=3)

aligned_images = []


print("\nStarten met uitlijnen...")
for i, f in enumerate(alle_fits):
    try:
        data = np.array(fits.getdata(f), dtype=np.float64)
        
        # Filter scherpe ruis en hot pixels weg uit de huidige frame
        data_clean = ndimage.median_filter(data, size=3)
        
        # Uitlijnen op basis van de opgeschoonde beelden
        aligned, footprint = aa.register(data_clean, ref_clean)
        
        aligned_images.append(aligned)
        print(f"{i+1}/{len(alle_fits)} OK")

    except Exception as e:
        print(f"{i+1}/{len(alle_fits)} SKIP: {e}")

print("\nAantal succesvol uitgelijnde frames:", len(aligned_images))

# 4. Controleren of er wel beelden zijn overgebleven
if len(aligned_images) == 0:
    raise RuntimeError("Geen enkele frame kon worden uitgelijnd. Controleer je referentieframe!")

# 5. Stacken met de mediaan om resterende satellietsporen/ruis te filteren
print("Beelden stacken...")
stack = np.median(aligned_images, axis=0)
stack = np.nan_to_num(stack)

# 6. Achtergrondcorrectie
background = np.median(stack)
stack = stack - background
stack[stack < 0] = 0

# 7. Logaritmische schaling (arcsinh) voor beter nevel-contrast
stack = np.arcsinh(stack)
stack = np.nan_to_num(stack)

# Percentielen bepalen voor de weergave
vmin = np.percentile(stack, 5)
vmax = np.percentile(stack, 99.7)

# 8. Resultaat plotten
plt.figure(figsize=(10, 10))
plt.imshow(stack, cmap='gray', vmin=vmin, vmax=vmax)
plt.title("H-alpha filter crabbie")
plt.colorbar(label="Intensiteit (arcsinh)")
plt.show()


